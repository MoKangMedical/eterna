# 念念 Eterna - Environment Configuration
# Copy this file to .env.local and fill in your values

# AI Model (required for chat features)
MIMO_API_KEY=
MIMO_BASE_URL=https://api.mimo.ai/v1
MIMO_CHAT_MODEL=mimo-v2-pro
MIMO_TTS_MODEL=mimo-v2-tts
MIMO_VIDEO_MODEL=mimo-v2-omni

# Stripe Billing (required for subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SEED=
STRIPE_PRICE_TREE=
STRIPE_PRICE_GARDEN=
STRIPE_PRICE_FAMILY=

# Twilio Phone Calls (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Server
HOST=0.0.0.0
PORT=8102
ALLOWED_ORIGINS=https://eterna-niannian.cloud

# FFmpeg (for video processing)
# FFMPEG_BIN=/usr/local/bin/ffmpeg
